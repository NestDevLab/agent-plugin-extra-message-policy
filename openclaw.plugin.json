{
  "id": "extra-message-policy",
  "name": "Extra Message Policy",
  "description": "Cross-platform message ingest and response policy enforcement.",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "defaultPolicy": {
        "$ref": "#/definitions/policy"
      },
      "policies": {
        "type": "array",
        "items": {
          "$ref": "#/definitions/policyRule"
        },
        "default": []
      },
      "jsonlSink": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "path": {
            "type": "string",
            "default": "runtime/extra-message-policy/messages.jsonl"
          },
          "shardBy": {
            "type": "string",
            "enum": [
              "none",
              "dayConversation"
            ],
            "default": "none"
          }
        }
      },
      "httpSink": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "url": {
            "type": "string"
          },
          "accessToken": {
            "type": "string"
          }
        }
      },
      "rawRecall": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "appendGuidance": {
            "type": "boolean",
            "default": true
          },
          "searchOnTriggerOnly": {
            "type": "boolean",
            "default": true
          },
          "rootPath": {
            "type": "string"
          },
          "maxDays": {
            "type": "integer",
            "minimum": 1,
            "default": 30
          },
          "maxMatches": {
            "type": "integer",
            "minimum": 1,
            "default": 12
          },
          "maxContextChars": {
            "type": "integer",
            "minimum": 500,
            "default": 6000
          },
          "triggerPhrases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tool": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "maxMatches": {
                "type": "integer",
                "minimum": 1,
                "default": 20
              },
              "maxContextChars": {
                "type": "integer",
                "minimum": 500,
                "default": 12000
              },
              "maxFiles": {
                "type": "integer",
                "minimum": 1,
                "default": 5000
              }
            }
          }
        }
      },
      "dedupeWindow": {
        "type": "integer",
        "minimum": 1,
        "default": 2000
      },
      "mentionDetection": {
        "type": "object",
        "additionalProperties": false,
        "description": "Optional fallback mention metadata used when a runtime hook does not expose provider wasMentioned flags.",
        "properties": {
          "botIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "botUserIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applicationIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "clientIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "botNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mentionPatterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/definitions/mentionDetectionAccount"
            }
          }
        }
      },
      "approvalPromptHandling": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "off",
              "cancel",
              "replace"
            ],
            "default": "off"
          },
          "replacementText": {
            "type": "string"
          }
        }
      },
      "directFollowupHandling": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "off",
              "sanitize-internal",
              "replace"
            ],
            "default": "off"
          },
          "replacementText": {
            "type": "string"
          }
        }
      },
      "policyCommand": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "commandName": {
            "type": "string",
            "default": "policy"
          },
          "applyDefault": {
            "type": "boolean",
            "default": false
          },
          "statePath": {
            "type": "string"
          },
          "defaultPolicy": {
            "$ref": "#/definitions/runtimePolicy"
          }
        }
      }
    },
    "definitions": {
      "runtimePolicy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "responseMode": {
            "type": "string",
            "enum": [
              "off",
              "mention",
              "always"
            ],
            "default": "off"
          },
          "ingestMode": {
            "type": "string",
            "enum": [
              "off",
              "passive",
              "responseCandidates",
              "all"
            ],
            "default": "off"
          }
        }
      },
      "mentionDetectionAccount": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "botIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "botUserIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applicationIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "clientIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "botNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mentionPatterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "policy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "respond": {
            "type": "boolean",
            "default": true
          },
          "ingestMode": {
            "type": "string",
            "enum": [
              "none",
              "passive",
              "all",
              "responseCandidates"
            ],
            "default": "responseCandidates"
          },
          "requireMention": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "policyRule": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "respond": {
            "type": "boolean",
            "default": true
          },
          "ingestMode": {
            "type": "string",
            "enum": [
              "none",
              "passive",
              "all",
              "responseCandidates"
            ],
            "default": "responseCandidates"
          },
          "channelId": {
            "type": "string"
          },
          "guildId": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "senderId": {
            "type": "string"
          },
          "isGroup": {
            "type": "boolean"
          },
          "sessionKeyIncludes": {
            "type": "string"
          },
          "sessionKeyRegex": {
            "type": "string"
          },
          "mentionTextRegex": {
            "type": "string",
            "description": "Optional regex fallback used by requireMention when provider mention metadata is unavailable."
          },
          "requireMention": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  },
  "contracts": {
    "tools": [
      "search_raw_context"
    ],
    "agentToolResultMiddleware": [
      "pi",
      "codex"
    ]
  }
}
